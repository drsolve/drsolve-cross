#!/bin/sh
# configure script - detects libraries and generates config.mk
# Usage: ./configure [options]
#
# Installation directories:
#   --prefix=PATH          Installation prefix (default: /usr/local, or /opt/homebrew on macOS arm64)
#   --exec-prefix=PATH     Executable-related prefix (default: PREFIX)
#   --bindir=PATH          User executables (default: EXEC_PREFIX/bin)
#   --libdir=PATH          Libraries (default: EXEC_PREFIX/lib)
#   --includedir=PATH      Header files (default: PREFIX/include/drsolve)
#   --mandir=PATH          Man pages (default: PREFIX/share/man/man1)
#
# Library locations:
#   --cc=COMPILER          Set C compiler (default: cc)
#   --flint-include=PATH   Set FLINT include path
#   --flint-lib=PATH       Set FLINT library path
#
# Build options:
#   --enable-static        Default build links all libraries statically
#   --disable-static       Default build uses dynamic linking (default)
#   --enable-asan          Enable AddressSanitizer (ASan) memory checking
#   --disable-asan         Disable AddressSanitizer (default)
#
#   --help                 Show this help

set -e

# ============================================================
# Defaults
# ============================================================
CC="${CC:-cc}"
ENABLE_ASAN="no"
ENABLE_STATIC="no"
HOST_OS=$(uname -s 2>/dev/null || echo unknown)
HOST_ARCH=$(uname -m 2>/dev/null || echo unknown)
DEFAULT_PREFIX="/usr/local"
if [ "$HOST_OS" = "Darwin" ] && { [ "$HOST_ARCH" = "arm64" ] || [ "$HOST_ARCH" = "aarch64" ]; } && [ -d /opt/homebrew/include ]; then
    DEFAULT_PREFIX="/opt/homebrew"
fi

# Install path sentinels: empty means "derive from PREFIX after arg parsing"
PREFIX=""
EXEC_PREFIX=""
BINDIR=""
LIBDIR=""
INCLUDEDIR=""
MANDIR=""

FLINT_INCLUDE_PATH="${FLINT_INCLUDE_PATH:-$DEFAULT_PREFIX/include}"
FLINT_LIB_PATH="${FLINT_LIB_PATH:-$DEFAULT_PREFIX/lib}"
PML_SOURCE_DIR="third_party/pml"
PML_INCLUDE_PATH="$PML_SOURCE_DIR/src"
PML_LIB_PATH="build/third_party/pml"

case "$HOST_OS" in
    Darwin)
        SHARED_LIB_EXT="dylib"
        SHARED_LDFLAGS="-dynamiclib"
        DEFAULT_SYSTEM_LIBS="-lmpfr -lgmp -lm"
        ;;
    *)
        SHARED_LIB_EXT="so"
        SHARED_LDFLAGS="-shared"
        DEFAULT_SYSTEM_LIBS="-lmpfr -lgmp -lm -lpthread -lstdc++"
        ;;
esac

# ============================================================
# Parse command-line arguments
# ============================================================
for arg in "$@"; do
    case "$arg" in
        --prefix=*)        PREFIX="${arg#--prefix=}" ;;
        --exec-prefix=*)   EXEC_PREFIX="${arg#--exec-prefix=}" ;;
        --bindir=*)        BINDIR="${arg#--bindir=}" ;;
        --libdir=*)        LIBDIR="${arg#--libdir=}" ;;
        --includedir=*)    INCLUDEDIR="${arg#--includedir=}" ;;
        --mandir=*)        MANDIR="${arg#--mandir=}" ;;
        --cc=*)            CC="${arg#--cc=}" ;;
        --flint-include=*) FLINT_INCLUDE_PATH="${arg#--flint-include=}" ;;
        --flint-lib=*)     FLINT_LIB_PATH="${arg#--flint-lib=}" ;;
        --enable-static)   ENABLE_STATIC="yes" ;;
        --disable-static)  ENABLE_STATIC="no" ;;
        --enable-asan)     ENABLE_ASAN="yes" ;;
        --disable-asan)    ENABLE_ASAN="no" ;;
        --help|-h)
            sed -n '2,26p' "$0"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            echo "Try './configure --help'"
            exit 1
            ;;
    esac
done

# ============================================================
# Resolve install path defaults (depend on PREFIX, so done
# after argument parsing)
# ============================================================
[ -z "$PREFIX" ]      && PREFIX="$DEFAULT_PREFIX"
[ -z "$EXEC_PREFIX" ] && EXEC_PREFIX="$PREFIX"
[ -z "$BINDIR" ]      && BINDIR="$EXEC_PREFIX/bin"
[ -z "$LIBDIR" ]      && LIBDIR="$EXEC_PREFIX/lib"
[ -z "$INCLUDEDIR" ]  && INCLUDEDIR="$PREFIX/include/drsolve"
[ -z "$MANDIR" ]      && MANDIR="$PREFIX/share/man/man1"

# Derive default link mode from --enable-static
if [ "$ENABLE_STATIC" = "yes" ]; then
    DEFAULT_LINK_MODE="static-all"
else
    DEFAULT_LINK_MODE="dynamic"
fi

append_space_list_unique() {
    _list="$1"
    _item="$2"
    case " $_list " in
        *" $_item "*) printf '%s' "$_list" ;;
        *)
            if [ -n "$_list" ]; then
                printf '%s %s' "$_list" "$_item"
            else
                printf '%s' "$_item"
            fi
            ;;
    esac
}

append_colon_paths() {
    _list="$1"
    _paths="$2"
    if [ -n "$_paths" ]; then
        OLD_IFS="$IFS"
        IFS=":"
        for p in $_paths; do
            [ -n "$p" ] && _list=$(append_space_list_unique "$_list" "$p")
        done
        IFS="$OLD_IFS"
    fi
    printf '%s' "$_list"
}

extract_flag_dirs() {
    _flags="$1"
    _kind="$2"
    _want_next="no"
    for tok in $_flags; do
        if [ "$_want_next" = "yes" ]; then
            [ -n "$tok" ] && printf '%s\n' "$tok"
            _want_next="no"
            continue
        fi
        case "$_kind:$tok" in
            I:-I|L:-L)
                _want_next="yes"
                ;;
            I:-I*)
                printf '%s\n' "${tok#-I}"
                ;;
            L:-L*)
                printf '%s\n' "${tok#-L}"
                ;;
        esac
    done
}

build_include_search_paths() {
    _paths="./include"
    _paths=$(append_colon_paths "$_paths" "$C_INCLUDE_PATH")
    for p in $(extract_flag_dirs "$CPPFLAGS $CFLAGS" I); do
        [ -n "$p" ] && _paths=$(append_space_list_unique "$_paths" "$p")
    done
    for p in         "$FLINT_INCLUDE_PATH"         "/usr/local/include"         "/opt/homebrew/include"         "/opt/local/include"         "/usr/include"
    do
        [ -n "$p" ] && [ -d "$p" ] && _paths=$(append_space_list_unique "$_paths" "$p")
    done
    _compiler_paths=$($CC -E -v - </dev/null 2>&1 | awk '
        /#include <\.\.\.> search starts here:/ { p=1; next }
        /End of search list/ { p=0 }
        p {
            sub(/^[[:space:]]+/, "", $0)
            sub(/[[:space:]]+\(framework directory\)$/, "", $0)
            sub(/[[:space:]]+\(system header\)$/, "", $0)
            sub(/[[:space:]]+$/, "", $0)
            if ($0 != "" && $0 !~ /^\(/) print $0
        }
    ' )
    _old_ifs="$IFS"
    IFS='
'
    for p in $_compiler_paths; do
        [ -n "$p" ] && _paths=$(append_space_list_unique "$_paths" "$p")
    done
    IFS="$_old_ifs"
    printf '%s' "$_paths"
}

detect_flint_version() {
    _header_dir="$1"
    _header="$_header_dir/flint/flint.h"

    if [ -f "$_header" ]; then
        _version=$(sed -n 's/^#define[[:space:]]\+FLINT_VERSION[[:space:]]\+"\([^"]*\)".*/\1/p' "$_header" | head -n 1)
        if [ -n "$_version" ]; then
            printf '%s' "$_version"
            return 0
        fi

        _major=$(sed -n 's/^#define[[:space:]]\+__FLINT_VERSION[[:space:]]\+\([0-9][0-9]*\).*/\1/p' "$_header" | head -n 1)
        _minor=$(sed -n 's/^#define[[:space:]]\+__FLINT_VERSION_MINOR[[:space:]]\+\([0-9][0-9]*\).*/\1/p' "$_header" | head -n 1)
        _patch=$(sed -n 's/^#define[[:space:]]\+__FLINT_VERSION_PATCHLEVEL[[:space:]]\+\([0-9][0-9]*\).*/\1/p' "$_header" | head -n 1)
        if [ -n "$_major" ] && [ -n "$_minor" ] && [ -n "$_patch" ]; then
            printf '%s.%s.%s' "$_major" "$_minor" "$_patch"
            return 0
        fi
    fi

    if [ -n "$_header_dir" ]; then
        $CC -E -dM -I"$_header_dir" -include flint/flint.h - < /dev/null 2>/dev/null | awk '
            $2 == "FLINT_VERSION" {
                gsub(/"/, "", $3)
                print $3
                found=1
                exit
            }
            $2 == "__FLINT_VERSION" { major=$3 }
            $2 == "__FLINT_VERSION_MINOR" { minor=$3 }
            $2 == "__FLINT_VERSION_PATCHLEVEL" { patch=$3 }
            END {
                if (!found && major != "" && minor != "" && patch != "") {
                    print major "." minor "." patch
                }
            }
        '
    fi
}

try_compile_with_flags() {
    _flags="$1"
    _code="$2"
    _src=".configure_flag_test.c"
    _obj=".configure_flag_test.o"

    printf '%s\n' "$_code" > "$_src"
    if eval "$CC $_flags -c -o $_obj $_src" >/dev/null 2>&1; then
        rm -f "$_src" "$_obj"
        return 0
    fi

    rm -f "$_src" "$_obj"
    return 1
}

try_link_with_flags() {
    _flags="$1"
    _code="$2"
    _src=".configure_flag_test.c"
    _exe=".configure_flag_test"

    printf '%s\n' "$_code" > "$_src"
    if eval "$CC $_flags -o $_exe $_src" >/dev/null 2>&1; then
        rm -f "$_src" "$_exe"
        return 0
    fi

    rm -f "$_src" "$_exe"
    return 1
}

detect_compiler_features() {
    _basic_test='int main(void){return 0;}'
    _omp_test='#include <omp.h>
int main(void){ return omp_get_max_threads() > 0 ? 0 : 1; }'

    ARCH_CFLAGS=""
    LTO_CFLAGS=""
    LTO_LDFLAGS=""
    OPENMP_AVAILABLE="no"
    OPENMP_CFLAGS=""
    OPENMP_LDFLAGS=""

    printf "checking for -march=native support... "
    if try_compile_with_flags "-march=native" "$_basic_test"; then
        ARCH_CFLAGS="-march=native"
        echo "yes"
    else
        echo "no"
    fi

    printf "checking for LTO support... "
    if try_link_with_flags "-flto=auto" "$_basic_test"; then
        LTO_CFLAGS="-flto=auto"
        LTO_LDFLAGS="-flto=auto"
        echo "yes (-flto=auto)"
    elif try_link_with_flags "-flto" "$_basic_test"; then
        LTO_CFLAGS="-flto"
        LTO_LDFLAGS="-flto"
        echo "yes (-flto)"
    else
        echo "no"
    fi

    printf "checking for OpenMP support... "
    if try_link_with_flags "-fopenmp" "$_omp_test"; then
        OPENMP_AVAILABLE="yes"
        OPENMP_CFLAGS="-fopenmp"
        OPENMP_LDFLAGS="-fopenmp"
        echo "yes (-fopenmp)"
        return 0
    fi

    if [ "$HOST_OS" = "Darwin" ]; then
        for _prefix in /opt/homebrew/opt/libomp /usr/local/opt/libomp /opt/homebrew /usr/local /opt/local; do
            _inc="$_prefix/include"
            _lib="$_prefix/lib"
            if [ -f "$_inc/omp.h" ] && [ -d "$_lib" ]; then
                _omp_cflags="-Xpreprocessor -fopenmp -I$_inc"
                _omp_ldflags="-L$_lib -lomp -Wl,-rpath,$_lib"
                if try_link_with_flags "$_omp_cflags $_omp_ldflags" "$_omp_test"; then
                    OPENMP_AVAILABLE="yes"
                    OPENMP_CFLAGS="$_omp_cflags"
                    OPENMP_LDFLAGS="$_omp_ldflags"
                    echo "yes ($_prefix)"
                    return 0
                fi
            fi
        done
    fi

    echo "no"
}

# ============================================================
# Helper: test if a header file physically exists under any
# include search path.  Does NOT invoke the preprocessor, so
# transitive #include failures can never cause a false "no".
# ============================================================
test_header() {
    _header="$1"
    _search_paths=$(build_include_search_paths)

    for _dir in $_search_paths; do
        [ -n "$_dir" ] && [ -f "$_dir/$_header" ] && echo "yes" && return 0
    done
    echo "no"
}

# ============================================================
# Helper: find the directory that actually contains a header.
# Returns the first matching search-path directory, or empty.
# ============================================================
find_header_dir() {
    _header="$1"
    _search_paths=$(build_include_search_paths)

    for _dir in $_search_paths; do
        if [ -n "$_dir" ] && [ -f "$_dir/$_header" ]; then
            echo "$_dir"
            return 0
        fi
    done
}

# ============================================================
# Build system library search paths
# ============================================================
SYSTEM_LIB_PATHS=""
SYSTEM_LIB_PATHS=$(append_colon_paths "$SYSTEM_LIB_PATHS" "$LIBRARY_PATH")
SYSTEM_LIB_PATHS=$(append_colon_paths "$SYSTEM_LIB_PATHS" "$LD_LIBRARY_PATH")
SYSTEM_LIB_PATHS=$(append_colon_paths "$SYSTEM_LIB_PATHS" "$DYLD_LIBRARY_PATH")
for p in $(extract_flag_dirs "$LDFLAGS $LIBS" L); do
    [ -n "$p" ] && SYSTEM_LIB_PATHS=$(append_space_list_unique "$SYSTEM_LIB_PATHS" "$p")
done
for p in     "$FLINT_LIB_PATH"     "$PML_LIB_PATH"     "/usr/lib"     "/usr/local/lib"     "/usr/lib64"     "/usr/local/lib64"     "/lib"     "/lib64"     "/usr/lib/x86_64-linux-gnu"     "/opt/homebrew/lib"     "/opt/local/lib"
do
    [ -n "$p" ] && [ -d "$p" ] && SYSTEM_LIB_PATHS=$(append_space_list_unique "$SYSTEM_LIB_PATHS" "$p")
done

# ============================================================
# Library search helpers
# ============================================================
find_shared_lib() {
    _name="$1"
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -d "$path" ]; then
            if [ -f "$path/lib$_name.$SHARED_LIB_EXT" ]; then echo "$path/lib$_name.$SHARED_LIB_EXT"; return 0; fi
            for f in "$path"/lib"$_name".$SHARED_LIB_EXT.*; do
                if [ -f "$f" ]; then echo "$f"; return 0; fi
            done
            if [ "$SHARED_LIB_EXT" = "dylib" ]; then
                for f in "$path"/lib"$_name".*.dylib; do
                    if [ -f "$f" ]; then echo "$f"; return 0; fi
                done
            fi
        fi
    done
}

find_static_lib() {
    _name="$1"
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -f "$path/lib$_name.a" ]; then
            echo "$path/lib$_name.a"
            return 0
        fi
    done
}

check_shared_lib() {
    _name="$1"
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -d "$path" ]; then
            if [ -f "$path/lib$_name.$SHARED_LIB_EXT" ]; then echo "yes"; return 0; fi
            for f in "$path"/lib"$_name".$SHARED_LIB_EXT.*; do
                if [ -f "$f" ]; then echo "yes"; return 0; fi
            done
            if [ "$SHARED_LIB_EXT" = "dylib" ]; then
                for f in "$path"/lib"$_name".*.dylib; do
                    if [ -f "$f" ]; then echo "yes"; return 0; fi
                done
            fi
        fi
    done
    echo "no"
}

check_static_lib() {
    _name="$1"
    for path in $SYSTEM_LIB_PATHS; do
        if [ -n "$path" ] && [ -f "$path/lib$_name.a" ]; then
            echo "yes"
            return 0
        fi
    done
    echo "no"
}

# ============================================================
# Run detection
# ============================================================
echo ""

# --- Compiler ---
printf "checking for C compiler... "
if command -v "$CC" >/dev/null 2>&1; then
    echo "$CC"
else
    echo "not found"
    echo "configure: error: C compiler '$CC' not found"
    exit 1
fi

# --- C_INCLUDE_PATH ---
if [ -n "$C_INCLUDE_PATH" ]; then
    printf "checking C_INCLUDE_PATH... "
    echo "$C_INCLUDE_PATH"
fi

# --- LD_LIBRARY_PATH ---
if [ -n "$LD_LIBRARY_PATH" ]; then
    printf "checking LD_LIBRARY_PATH... "
    echo "$LD_LIBRARY_PATH"
fi

# --- FLINT headers (required) ---
printf "checking for flint/flint.h... "
FLINT_HEADER_CHECK=$(test_header "flint/flint.h")
echo "$FLINT_HEADER_CHECK"

if [ "$FLINT_HEADER_CHECK" != "yes" ]; then
    echo "configure: error: FLINT headers not found!"
    echo "  Compiler cannot find flint/flint.h."
    echo "  Check C_INCLUDE_PATH/CPPFLAGS or install FLINT development packages."
    rm -f "$TEMP_TEST_FILE"
    exit 1
fi

FLINT_HEADER_DIR=$(find_header_dir "flint/flint.h")

printf "checking FLINT version... "
FLINT_VERSION=$(detect_flint_version "$FLINT_HEADER_DIR")
if [ -n "$FLINT_VERSION" ]; then
    echo "$FLINT_VERSION"
else
    FLINT_VERSION="unknown"
    echo "$FLINT_VERSION"
fi

# --- FLINT include directory ---
printf "checking for FLINT include directory... "
FLINT_DIR_EXISTS="no"
if [ -d "$FLINT_INCLUDE_PATH" ]; then
    FLINT_DIR_EXISTS="yes"
    echo "$FLINT_INCLUDE_PATH"
elif [ -n "$FLINT_HEADER_DIR" ]; then
    FLINT_INCLUDE_PATH="$FLINT_HEADER_DIR"
    FLINT_DIR_EXISTS="yes"
    echo "$FLINT_INCLUDE_PATH (from compiler/include search path)"
else
    echo "not found at $FLINT_INCLUDE_PATH (using compiler search paths)"
fi

# --- FLINT libraries (required) ---
printf "checking for FLINT shared library... "
FLINT_DYNAMIC_LIB_CHECK=$(check_shared_lib "flint")
FLINT_SO_PATH=$(find_shared_lib "flint")
if [ "$FLINT_DYNAMIC_LIB_CHECK" = "yes" ]; then
    echo "$FLINT_SO_PATH"
else
    echo "no"
fi

printf "checking for FLINT static library... "
FLINT_STATIC_LIB_CHECK=$(check_static_lib "flint")
FLINT_A_PATH=$(find_static_lib "flint")
if [ "$FLINT_STATIC_LIB_CHECK" = "yes" ]; then
    echo "$FLINT_A_PATH"
else
    echo "no"
fi

if [ "$FLINT_DYNAMIC_LIB_CHECK" = "yes" ] && [ -n "$FLINT_SO_PATH" ]; then
    FLINT_LIB_PATH=$(dirname "$FLINT_SO_PATH")
elif [ "$FLINT_STATIC_LIB_CHECK" = "yes" ] && [ -n "$FLINT_A_PATH" ]; then
    FLINT_LIB_PATH=$(dirname "$FLINT_A_PATH")
elif [ -n "$FLINT_HEADER_DIR" ]; then
    _flint_prefix=${FLINT_HEADER_DIR%/include}
    if [ "$_flint_prefix" != "$FLINT_HEADER_DIR" ] && [ -d "$_flint_prefix/lib" ]; then
        FLINT_LIB_PATH="$_flint_prefix/lib"
    fi
fi

if [ ! -d "$FLINT_LIB_PATH" ]; then
    echo "configure: error: FLINT libraries not found!"
    echo "  Linker cannot find libflint.$SHARED_LIB_EXT or libflint.a."
    echo "  Check LDFLAGS/LIBRARY_PATH or install FLINT development packages."
    exit 1
fi

# --- Bundled PML ---
printf "checking for bundled PML source directory... "
PML_DIR_EXISTS="no"
if [ -d "$PML_SOURCE_DIR" ]; then
    PML_DIR_EXISTS="yes"
    echo "$PML_SOURCE_DIR"
else
    echo "not found"
fi

printf "checking for bundled PML header pml.h... "
if [ -f "$PML_INCLUDE_PATH/pml.h" ]; then
    PML_HEADER_CHECK="yes"
    PML_HEADER_PREFIX=""
    PML_HEADER_DIR="$PML_INCLUDE_PATH"
    echo "yes"
else
    PML_HEADER_CHECK="no"
    PML_HEADER_PREFIX=""
    PML_HEADER_DIR=""
    echo "no"
fi

printf "checking for bundled nmod_poly_mat_utils.h... "
if [ -f "$PML_INCLUDE_PATH/nmod_poly_mat_utils.h" ]; then
    NMOD_POLY_MAT_UTILS_CHECK="yes"
    echo "yes"
else
    NMOD_POLY_MAT_UTILS_CHECK="no"
    echo "no"
fi

printf "checking for bundled nmod_poly_mat_extra.h... "
if [ -f "$PML_INCLUDE_PATH/nmod_poly_mat_extra.h" ]; then
    NMOD_POLY_MAT_EXTRA_CHECK="yes"
    echo "yes"
else
    NMOD_POLY_MAT_EXTRA_CHECK="no"
    echo "no"
fi

printf "checking bundled PML link mode... "
PML_DYNAMIC_LIB_CHECK="no"
PML_SO_PATH=""
echo "static only"

printf "checking bundled PML static library output... "
PML_A_PATH="$PML_LIB_PATH/libpml.a"
if [ "$PML_DIR_EXISTS" = "yes" ]; then
    PML_STATIC_LIB_CHECK="yes"
    echo "$PML_A_PATH (will be built by make)"
else
    PML_STATIC_LIB_CHECK="no"
    echo "unavailable"
fi

# --- System libraries ---
printf "checking for -lmpfr... "
if [ "$(test_header mpfr.h)" = "yes" ]; then echo "yes"; else echo "no (continuing anyway)"; fi

printf "checking for -lgmp... "
if [ "$(test_header gmp.h)" = "yes" ]; then echo "yes"; else echo "no (continuing anyway)"; fi

# --- AddressSanitizer ---
ASAN_CFLAGS=""
ASAN_LDFLAGS=""
printf "checking whether to enable AddressSanitizer... "
if [ "$ENABLE_ASAN" = "yes" ]; then
    echo "yes"
    printf "checking for -fsanitize=address support... "
    _asan_tmp=".configure_asan_test.c"
    echo "int main(){return 0;}" > "$_asan_tmp"
    if $CC -fsanitize=address -static-libasan -o /dev/null "$_asan_tmp" >/dev/null 2>&1; then
        echo "yes"
        ASAN_CFLAGS="-fsanitize=address -static-libasan"
        ASAN_LDFLAGS="-fsanitize=address -static-libasan"
    elif $CC -fsanitize=address -o /dev/null "$_asan_tmp" >/dev/null 2>&1; then
        echo "yes (without static-libasan)"
        ASAN_CFLAGS="-fsanitize=address"
        ASAN_LDFLAGS="-fsanitize=address"
    else
        echo "no"
        echo "configure: warning: compiler does not support -fsanitize=address, ASan disabled"
        ENABLE_ASAN="no"
    fi
    rm -f "$_asan_tmp"
else
    echo "no (use --enable-asan to enable)"
fi

# --- Compiler feature detection ---
detect_compiler_features

# ============================================================
# Determine PML availability
# ============================================================
echo ""
PML_AVAILABLE="no"
if [ "$PML_HEADER_CHECK" = "yes" ] && \
   [ "$NMOD_POLY_MAT_UTILS_CHECK" = "yes" ] && \
   [ "$NMOD_POLY_MAT_EXTRA_CHECK" = "yes" ] && \
   [ "$PML_STATIC_LIB_CHECK" = "yes" ]; then
    PML_AVAILABLE="yes"
fi

if [ "$PML_AVAILABLE" = "yes" ]; then
    echo "*** bundled PML source FOUND - will build with bundled static PML support ***"
else
    echo "*** bundled PML source NOT FOUND - will build without PML support ***"
fi

# ============================================================
# Compute derived variables (mirrors original Makefile logic)
# ============================================================
# Include flags
INCLUDE_FLAGS="-I./include"
if [ "$PML_AVAILABLE" = "yes" ]; then
    INCLUDE_FLAGS="-I$PML_INCLUDE_PATH $INCLUDE_FLAGS"
fi
for p in $(build_include_search_paths); do
    if [ -n "$p" ] && [ "$p" != "./include" ]; then
        INCLUDE_FLAGS="$INCLUDE_FLAGS -I$p"
    fi
done

# Preprocessor defines
FLINT_FLAGS="-DHAVE_FLINT"
PML_FLAGS=""
if [ "$PML_AVAILABLE" = "yes" ]; then
    PML_FLAGS="-DHAVE_PML -DPML_HAVE_MACHINE_VECTORS=0"
fi

# PML linking
PML_LIBS=""
PML_STATIC_LIBS=""
if [ "$PML_AVAILABLE" = "yes" ]; then
    PML_LIBS="$PML_A_PATH"
    PML_STATIC_LIBS="$PML_A_PATH"
fi

# RPATH
RPATH_FLAGS="-Wl,-rpath,$FLINT_LIB_PATH -Wl,-rpath,."

# ============================================================
# Write config.mk
# ============================================================
CONFIG_FILE="config.mk"
printf "creating %s... " "$CONFIG_FILE"

cat > "$CONFIG_FILE" << ENDOFCONFIG
# Generated by ./configure on $(date)
# Do not edit -- re-run ./configure instead.

# Compiler
CC = $CC
HOST_OS = $HOST_OS

# Installation directories
PREFIX      = $PREFIX
EXEC_PREFIX = $EXEC_PREFIX
BINDIR      = $BINDIR
LIBDIR      = $LIBDIR
INCLUDEDIR  = $INCLUDEDIR
MANDIR      = $MANDIR

# Default link mode: dynamic | static-all
DEFAULT_LINK_MODE = $DEFAULT_LINK_MODE

# Library search paths
FLINT_INCLUDE_PATH = $FLINT_INCLUDE_PATH
FLINT_LIB_PATH = $FLINT_LIB_PATH
PML_INCLUDE_PATH = $PML_INCLUDE_PATH
PML_LIB_PATH = $PML_LIB_PATH

# Detection results
FLINT_HEADER_CHECK = $FLINT_HEADER_CHECK
FLINT_HEADER_DIR = $FLINT_HEADER_DIR
FLINT_VERSION = $FLINT_VERSION
